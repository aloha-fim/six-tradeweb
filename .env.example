# Copy to .env and adjust.

# Async Postgres DSN (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://six:six@localhost:5432/six_tradeweb

# Tradeweb data feed. Leave TRADEWEB_USE_MOCK=true to run with the built-in
# synthetic feed and no credentials. Set to false and supply a key to call live.
TRADEWEB_USE_MOCK=true
TRADEWEB_BASE_URL=https://api.tradeweb.example/v1
# TRADEWEB_API_KEY=

ENVIRONMENT=local
